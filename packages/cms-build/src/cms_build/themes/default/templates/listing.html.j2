{% extends "base.html.j2" %}
{% block main %}
<section class="listing">
  <h1>{{ listing.title }}</h1>
  {% if listing.search_index_url %}
  <site-search index-url="{{ listing.search_index_url }}" label="{{ listing.search_label }}"></site-search>
  <script type="module" src="{{ asset_urls['assets/search.js'] }}"></script>
  {% endif %}
  <ul class="entries">
  {% for entry in listing.entries %}
    <li>
      <a href="{{ entry.url }}">{{ entry.title }}</a>
      {% if entry.summary %}<p>{{ entry.summary }}</p>{% endif %}
      <time datetime="{{ entry.date_iso }}">{{ entry.date_iso }}</time>
    </li>
  {% endfor %}
  </ul>
  {% if listing.pages > 1 %}
  <nav class="pagination" aria-label="Pagination">
    {% if listing.previous_url %}<a rel="prev" href="{{ listing.previous_url }}">&larr;</a>{% endif %}
    <span>{{ listing.page }} / {{ listing.pages }}</span>
    {% if listing.next_url %}<a rel="next" href="{{ listing.next_url }}">&rarr;</a>{% endif %}
  </nav>
  {% endif %}
</section>
{% endblock %}
