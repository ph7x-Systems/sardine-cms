{% extends "shell.html.j2" %}
{% block title %}Media — Sardine CMS admin{% endblock %}
{% block content %}
<span class="admin-kick">Content</span>
<h1>Media</h1>
<p><a class="admin-btn admin-btn-primary" href="/media/new">Upload media</a></p>
{% if assets %}
<div class="admin-table-wrap">
  <table class="admin-table">
    <thead>
      <tr>
        <th scope="col">Preview</th>
        <th scope="col">ID</th>
        <th scope="col">Type</th>
        <th scope="col">Size</th>
        <th scope="col">Alt (EN)</th>
        <th scope="col">Translated alt</th>
      </tr>
    </thead>
    <tbody>
      {% for asset in assets %}
      <tr>
        <td>{% if asset.is_image %}<img class="admin-thumb" src="/media-files/{{ asset.path }}"
              alt="" width="72" height="48" loading="lazy">{% endif %}</td>
        <th scope="row"><a href="/media/{{ asset.id }}">{{ asset.id }}</a></th>
        <td>{{ asset.mime_type }}</td>
        <td>{% if asset.width %}{{ asset.width }}×{{ asset.height }}{% endif %}</td>
        <td>{{ asset.alt.get(source_language, "") }}</td>
        <td>
          {% set missing = asset.missing_alt_languages() %}
          {% if missing %}
          <span class="admin-state admin-state-missing">{{ missing | map(attribute="value") | join(", ") }}</span>
          {% else %}
          <span class="admin-state admin-state-complete">complete</span>
          {% endif %}
        </td>
      </tr>
      {% endfor %}
    </tbody>
  </table>
</div>
{% else %}
<p class="admin-empty">No media yet — upload the first asset.</p>
{% endif %}
{% endblock %}
