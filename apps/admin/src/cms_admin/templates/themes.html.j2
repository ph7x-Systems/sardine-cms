{% extends "shell.html.j2" %}
{% block title %}{{ _("Themes") }} — Sardine CMS admin{% endblock %}
{% block header %}<h1 class="h3 mb-0">{{ _("Themes") }}</h1>{% endblock %}
{% block content %}

{% if activated %}
<div class="alert alert-success" role="status">
  {{ _("Activated %(name)s — the change applies to the next build and preview.") | format(name=activated) }}
</div>
{% endif %}
{% if error %}
<div class="alert alert-danger" role="alert">
  {{ _("Activation failed and the configuration was left untouched: %(error)s") | format(error=error) }}
</div>
{% endif %}
{% if active_error %}
<div class="alert alert-warning" role="alert">
  {{ _("The active theme fails to load: %(error)s") | format(error=active_error) }}
</div>
{% endif %}

<div class="card">
  <div class="card-header"><h2 class="card-title h6 mb-0">{{ _("Installed themes") }}</h2></div>
  {% if not has_project %}
  <div class="card-body"><p class="admin-empty mb-0">{{ _("No project configuration was found; themes activate per project.") }}</p></div>
  {% else %}
  <div class="card-body">
    <p class="mb-0">{{ _("Themes install with the environment's package manager and appear here on their own. Activation tries a full build first — a failing theme never reaches the configuration.") }}</p>
  </div>
  <div class="card-body p-0 table-responsive admin-table-wrap border-top">
    <table class="table table-striped mb-0 admin-table">
      <thead><tr>
        <th scope="col">{{ _("Theme") }}</th>
        <th scope="col">{{ _("Package") }}</th>
        <th scope="col">{{ _("Version") }}</th>
        <th scope="col">{{ _("Status") }}</th>
      </tr></thead>
      <tbody>
        {% for theme in themes %}
        <tr>
          <th scope="row">{{ theme.name }}</th>
          <td>{{ theme.distribution or _("Built-in") }}</td>
          <td>{{ theme.version or "—" }}</td>
          <td>
            {% if theme.name == active %}
            <span class="badge text-bg-success admin-state admin-state-complete">{{ _("Active") }}</span>
            {% else %}
            <form method="post" action="/themes/activate" class="d-inline">
              <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
              <input type="hidden" name="name" value="{{ theme.name }}">
              <button type="submit" class="btn btn-sm btn-outline-primary">{{ _("Activate") }}</button>
            </form>
            {% endif %}
          </td>
        </tr>
        {% endfor %}
      </tbody>
    </table>
  </div>
  {% endif %}
</div>
{% endblock %}
