{% extends "shell.html.j2" %}
{% from "_fields.html.j2" import errors_block %}
{% block title %}{{ asset.id }} — Sardine CMS admin{% endblock %}
{% block content %}
<nav class="admin-breadcrumb" aria-label="Breadcrumb"><a href="/media">&larr; Media</a></nav>
<h1>{{ asset.id }} <span class="admin-tag">{{ asset.mime_type }}</span></h1>
{{ errors_block(errors) }}
<div class="admin-sbs">
  <section aria-labelledby="preview-heading">
    <h2 id="preview-heading">Preview</h2>
    {% if asset.is_image %}
    <div class="admin-preview admin-media-preview">
      <img src="/media-files/{{ asset.path }}" alt="{{ asset.alt.values() | list | first }}"
           width="{{ asset.width }}" height="{{ asset.height }}">
    </div>
    {% endif %}
    <dl class="admin-source">
      <dt>Path</dt><dd><code>{{ asset.path }}</code></dd>
      {% if asset.width %}<dt>Dimensions</dt><dd>{{ asset.width }}×{{ asset.height }}</dd>{% endif %}
    </dl>
    <h3>Used by</h3>
    {% if references %}
    <ul>{% for reference in references %}<li><code>{{ reference }}</code></li>{% endfor %}</ul>
    <p class="admin-hint">Referenced assets cannot be deleted.</p>
    {% else %}
    <p class="admin-empty">Nothing references this asset.</p>
    <form method="post" action="/media/{{ asset.id }}/delete">
      <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
      <button type="submit" class="admin-btn">Delete asset</button>
    </form>
    {% endif %}
  </section>
  <form method="post" action="/media/{{ asset.id }}" class="admin-form">
    <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
    <fieldset>
      <legend>Alt text</legend>
      <div class="admin-field">
        <label for="alt_en">EN (mandatory)</label>
        <input class="admin-input" id="alt_en" name="alt_en" value="{{ form.alt_en }}" required>
      </div>
      {% for language in target_languages %}
      <div class="admin-field">
        <label for="alt_{{ language.value }}">{{ language.value | upper }}</label>
        <input class="admin-input" id="alt_{{ language.value }}"
               name="alt_{{ language.value }}" value="{{ form["alt_" + language.value] }}">
      </div>
      {% endfor %}
    </fieldset>
    <div>
      <button type="submit" class="admin-btn admin-btn-primary">Save alt text</button>
    </div>
  </form>
</div>
{% endblock %}
