{% extends "base.html.j2" %}
{% block title %}Dashboard — Stillsite admin{% endblock %}
{% block content %}
<h1>Stillsite admin</h1>
<p>Signed in as <strong>{{ user.username }}</strong> ({{ user.role.value }}).</p>
<form method="post" action="/logout">
  <input type="hidden" name="csrf_token" value="{{ csrf_token }}">
  <button type="submit">Sign out</button>
</form>
{% endblock %}
